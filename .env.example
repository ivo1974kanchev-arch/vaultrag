# ---------------------------------------------------------------
# vaultrag — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ---------------------------------------------------------------

# Supabase — project credentials (Settings > API in Supabase dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co          # Project URL
SUPABASE_ANON_KEY=your-anon-public-key-here                # Safe to expose to clients
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here       # Server-side only — keep secret

# License server — HMAC signing secret for license key generation
# Generate with: openssl rand -hex 32
LICENSE_SERVER_SECRET=replace-with-32-byte-hex-secret

# Google Play — used by the license server to verify purchase receipts
GOOGLE_PLAY_PACKAGE_NAME=com.yourorg.vaultrag              # Android package name
GOOGLE_PLAY_API_KEY=your-google-play-developer-api-key    # Play Developer API credentials JSON or key

# Cloudflare Workers — used by Wrangler for deployment
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token             # Workers & Pages edit permission

# Application
ENVIRONMENT=development                                     # development | production
APP_VERSION=1.0.0                                          # Mirrors app versionName